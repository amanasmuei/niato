#!/usr/bin/env node
// Nawaitu CLI dispatcher (Node-based, no pnpm dependency).
// Routes subcommands to compiled entries under dist/. See
// src/cli/dispatch.ts for the pure routing logic.

import { spawn } from "node:child_process";
import { readFileSync } from "node:fs";
import { fileURLToPath } from "node:url";
import { dirname, join } from "node:path";
import { resolveDispatch, helpText } from "../dist/cli/dispatch.js";

const here = dirname(fileURLToPath(import.meta.url));
const pkgRoot = join(here, "..");
const distRoot = join(pkgRoot, "dist");

const args = process.argv.slice(2);
const result = resolveDispatch(args);

if (result.kind === "version") {
  const pkg = JSON.parse(readFileSync(join(pkgRoot, "package.json"), "utf8"));
  process.stdout.write(`${pkg.version}\n`);
  process.exit(0);
}

if (result.kind === "help") {
  process.stdout.write(`${helpText()}\n`);
  process.exit(0);
}

if (result.kind === "unknown") {
  process.stderr.write(`nawaitu: unknown subcommand '${result.subcommand}'\n`);
  process.stderr.write("Run `nawaitu --help` for usage.\n");
  process.exit(2);
}

const child = spawn(
  process.execPath,
  [join(distRoot, result.entry), ...result.forwardArgs],
  { stdio: "inherit" },
);
child.on("exit", (code, signal) => {
  if (signal !== null) process.kill(process.pid, signal);
  else process.exit(code ?? 1);
});
child.on("error", (err) => {
  process.stderr.write(`nawaitu: failed to launch entry: ${err.message}\n`);
  process.exit(1);
});
